{
  "name": "orphanage",
  "publisher": "nyght",
  "displayName": "Orphanage",
  "description": "All your files, parentless and afraid.",
  "version": "0.0.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/BenNyght/Orphanage.git"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:orphanage.json",
    "onLanguage:typescript",
    "onLanguage:javascript"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "Orphanage.flatten",
        "title": "Orphanage: Flatten Project"
      },
      {
        "command": "Orphanage.createConfig",
        "title": "Orphanage: Create Default Config"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "orphanageContainer",
          "title": "Orphanage",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "orphanageContainer": [
        {
          "icon": "media/icon.svg",
          "type": "webview",
          "id": "orphanageView",
          "name": "Controls"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "build": "tsc"
  },
  "devDependencies": {
    "@types/vscode": "^1.98.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "esbuild": "^0.25.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.2",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1"
  }
}